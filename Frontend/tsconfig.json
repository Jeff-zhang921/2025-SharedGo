{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["DOM", "ESNext"],
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",   // compiled files go here
    "noEmit": true,      // prevents TS from writing JS files, Vite handles it
    "types": ["vite/client"]
  },
  "include": ["src"]
}
