{
  "family": "sharedgo_frontend_task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::588738568626:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "frontend_container",
      "image": "588738568626.dkr.ecr.eu-north-1.amazonaws.com/sharedgo-frontend:latest",
      "portMappings": [
        {
          "containerPort": 80,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/sharedgo_frontend",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}