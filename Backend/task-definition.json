{
  "family": "sharedgo-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::588738568626:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "backend_container",
      "image": "placeholder",
      "cpu": 256,
      "memory": 512,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
            "name": "DATABASE_URL",
            "valueFrom": "arn:aws:ssm:eu-north-1:123456789012:parameter/database_url"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/sharedgo",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ] 
}