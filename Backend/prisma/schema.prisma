generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int                @id @default(autoincrement())
  email           String             @unique
  name            String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  eventsHosted    Event[]
  registrations   EventParticipant[]
  authoredReviews Review[]           @relation("UserReviews")
  hostReviews     Review[]           @relation("HostReviews")
}

model Event {
  id           Int                @id @default(autoincrement())
  title        String
  description  String?
  startsAt     DateTime
  capacity     Int?
  location     String
  imageUrl     String?
  externalUrl  String?
  hostId       Int
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  category     Category           @default(Other)
  latitude     Float
  longitude    Float
  host         User               @relation(fields: [hostId], references: [id])
  participants EventParticipant[]
  reviews      Review[]
}

model EventParticipant {
  id       Int      @id @default(autoincrement())
  eventId  Int
  userId   Int
  joinedAt DateTime @default(now())
  event    Event    @relation(fields: [eventId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int?
  comment   String?
  eventId   Int
  hostId    Int
  authorId  Int
  createdAt DateTime @default(now())
  author    User     @relation("UserReviews", fields: [authorId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])
  host      User     @relation("HostReviews", fields: [hostId], references: [id])

  @@unique([eventId, authorId])
  @@index([hostId, createdAt])
}

model LoginCode {
  id        Int       @id @default(autoincrement())
  email     String
  codeHash  String
  expiresAt DateTime
  attempts  Int       @default(0)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email, expiresAt])
}

enum Category {
  Physical_Activities
  Festivals
  Educational
  Networking
  Arts_Culture
  Food_Drink
  Music_Concerts
  Tech_Gaming
  Wellness_Meditation
  Volunteer_Charity
  Other
}

model EventParticipant { // Join table linking users to events they attend.
  id        Int      @id @default(autoincrement()) 
  eventId   Int // Foreign key referencing the event joined.
  userId    Int // Foreign key referencing the user who joined.
  joinedAt  DateTime @default(now())


  event Event @relation(fields: [eventId], references: [id]) // Relation to fetch the associated event.
  user  User  @relation(fields: [userId], references: [id]) // Relation to fetch the associated user.

  @@unique([eventId, userId]) // Prevent duplicate participation records for the same user and event.
} 

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int?
  comment   String?
  eventId   Int
  hostId    Int
  authorId  Int
  createdAt DateTime @default(now())

  event  Event @relation(fields: [eventId], references: [id])
  host   User  @relation("HostReviews", fields: [hostId], references: [id])
  author User  @relation("UserReviews", fields: [authorId], references: [id])

// The combination of (eventId, authorId) must be unique.
  @@unique([eventId, authorId])
  @@index([hostId, createdAt])
}

model LoginCode {
  id        Int      @id @default(autoincrement())
  email     String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email, expiresAt])
}
